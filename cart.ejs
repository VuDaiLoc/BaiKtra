<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">
<head>
<meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
<title>Cart | Flower Shop</title>
<link href="templatemo_style.css" rel="stylesheet" type="text/css" />
<style>
  table { width: 100%; border-collapse: collapse; color: #fff; margin-bottom: 20px; }
  th { background: #440522; padding: 8px 10px; text-align: left; }
  td { padding: 8px 10px; border-bottom: 1px solid #be457c; }
  .total-row td { font-weight: bold; font-size: 16px; background: #440522; }
</style>
</head>
<body>
<div id="templatemo_container">

  <div id="templatemo_top_panel">
    <div id="templatemo_language_section">
      <a href="#"><img src="images/templatemo_flag_01.gif" alt="flag 1" /></a>
    </div>
    <div id="templatemo_shopping_cart">
      Shopping Cart <span>(<a href="/cart"><%= cartCount %> items</a>)</span>
    </div>
  </div>

  <div id="templatemo_header">
    <img src="images/templatemo_site_header.jpg" alt="Flower Shop" />
  </div>

  <div id="templatemo_banner">
    <a href="/"><img src="images/templatemo_banner_image.jpg" alt="Flower Shop" border="0" /></a>
  </div>

  <div id="templatemo_menu_panel">
    <ul>
      <li><a href="/">Home</a></li>
      <li><a href="/shop">Shop</a></li>
      <li><a href="/about">About Us</a></li>
      <li><a href="/contact">Contact Us</a></li>
      <li><a href="/cart" class="current">Cart</a></li>
    </ul>
  </div>

  <div id="templatemo_content">
    <div id="templatemo_content_left">
      <h1>Giỏ Hàng</h1>

      <div class="cleaner_with_height">&nbsp;</div>
      <h2>Sản Phẩm Đã Chọn</h2>

      <table>
        <thead>
          <tr>
            <th>Sản phẩm</th>
            <th>Giá</th>
            <th>Số lượng</th>
            <th>Thành tiền</th>
          </tr>
        </thead>
        <tbody>
          <% var total = 0; %>
          <% cartItems.forEach(function(item) { %>
          <% var subtotal = (parseFloat(item.product.price) * item.qty).toFixed(2); %>
          <% total += parseFloat(subtotal); %>
          <tr>
            <td><%= item.product.name %></td>
            <td>$<%= item.product.price %></td>
            <td><%= item.qty %></td>
            <td>$<%= subtotal %></td>
          </tr>
          <% }); %>
          <tr class="total-row">
            <td colspan="3">TOTAL</td>
            <td>$<%= total.toFixed(2) %></td>
          </tr>
        </tbody>
      </table>

      <div class="buynow"><a href="/shop">Tiếp tục mua</a></div>
      <div class="cleaner_with_height">&nbsp;</div>
    </div>

    <div id="templatemo_content_right">
      <div class="templatemo_right_section">
        <h4>Categories</h4>
        <div class="templatemo_right_section_content">
          <ul>
            <li><a href="#">Fresh Cut</a></li>
            <li><a href="#">Gifts</a></li>
            <li><a href="#">Weddings</a></li>
          </ul>
        </div>
      </div>
    </div>

    <div class="cleaner">&nbsp;</div>
  </div>

  <div id="templatemo_footer_panel">
    <div id="footer_left">
      <img src="images/mastercard.gif" alt="Master Card" />
      <img src="images/visa.gif" alt="Visa Card" />
      <img src="images/paypal.gif" alt="PayPal" />
    </div>
    <div id="footer_right">
      Copyright &copy; 2024 <a href="#">Flower Shop</a>
    </div>
    <div class="cleaner">&nbsp;</div>
  </div>

</div>
</body>
</html>
